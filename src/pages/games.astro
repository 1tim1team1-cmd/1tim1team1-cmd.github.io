---
import Layout from '../layouts/Layout.astro';
---
<Layout title="timteam · Игры" description="Игра про Кэсси — аниме + triple-A проект на Unity">
<div style="max-width:800px;margin:0 auto;padding:40px 24px 100px;">
  <div class="anim-up"><span class="tag">Unity · C# · аниме · triple-A</span></div>
  <h1 class="anim-up-2" style="font-size:clamp(32px,5vw,56px);font-weight:700;letter-spacing:-.02em;margin:16px 0 32px;">Игры</h1>

  <div class="glass anim-up-3" style="border-radius:28px;padding:32px;margin-bottom:24px;display:flex;gap:24px;flex-wrap:wrap;align-items:flex-start;">
    <div style="width:120px;height:120px;border-radius:20px;background:linear-gradient(135deg,#7c3aed,#e879f9);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:48px;">🧝‍♀️</div>
    <div style="flex:1;min-width:200px;">
      <div class="tag" style="margin-bottom:12px;">В разработке</div>
      <h2 style="font-size:24px;font-weight:700;margin-bottom:8px;">Проект Кэсси</h2>
      <p style="font-size:14px;color:var(--text-muted);line-height:1.8;">
        Аниме-адвенчура про эльфийку Кэсси — авторский персонаж, смоделированный в Blender с нуля. Разрабатываю на Unity, стремлюсь к качеству triple-A. Уникальная история, авторская музыка, 3D-анимация.
      </p>
    </div>
  </div>

  <div class="anim-up-4" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:40px;">
    {[
      {icon:"🎮", label:"Движок", val:"Unity"},
      {icon:"🏗️", label:"Язык", val:"C#"},
      {icon:"🎨", label:"3D", val:"Blender"},
      {icon:"🎵", label:"Музыка", val:"FL Studio"},
    ].map(s => (
      <div class="glass" style="padding:18px 20px;border-radius:18px;">
        <div style="font-size:24px;margin-bottom:8px;">{s.icon}</div>
        <div style="font-size:11px;color:var(--text-hint);margin-bottom:2px;">{s.label}</div>
        <div style="font-size:15px;font-weight:600;">{s.val}</div>
      </div>
    ))}
  </div>

  <div class="glass anim-up-5" style="padding:24px 28px;border-radius:24px;text-align:center;">
    <div style="font-size:14px;color:var(--text-muted);">Следи за разработкой в Telegram</div>
    <a href="https://t.me/Timteam_Universe" target="_blank" class="btn btn-primary" style="margin-top:16px;">Timteam Universe</a>
  </div>
</div>
</Layout>