---
import Layout from '../layouts/Layout.astro';
---
<Layout title="timteam · Обо мне">
<div style="max-width:720px;margin:0 auto;padding:40px 24px 100px;text-align:center;">
  <div class="anim-up"><span class="tag">17 лет · самоучка · Россия</span></div>
  <h1 class="anim-up-2" style="font-size:clamp(32px,5vw,56px);font-weight:700;letter-spacing:-.02em;margin:16px 0 32px;">Привет, я Тим</h1>

  <div class="glass anim-up-3" style="border-radius:28px;padding:32px;text-align:left;margin-bottom:24px;">
    <p style="font-size:15px;color:var(--text-muted);line-height:1.8;margin-bottom:20px;">
      Занимаюсь 3D-графикой, музыкой и разработкой — всё самоучка, всё из интереса. Blender освоил раньше, чем научился нормально объяснять что делаю. FL Studio — мой способ говорить без слов.
    </p>
    <p style="font-size:15px;color:var(--text-muted);line-height:1.8;">
      Сейчас делаю аниме-игру про эльфийку Кэсси — моя самая большая и любимая работа. Планирую Jarvis-подобный AI и ещё много всего.
    </p>
  </div>

  <div class="anim-up-4" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:40px;">
    {[
      {label:"3D / Blender", level:"Продвинутый"},
      {label:"After Effects", level:"Продвинутый"},
      {label:"FL Studio", level:"Продвинутый"},
      {label:"Unity / C#", level:"Начинающий"},
      {label:"Python", level:"Начинающий"},
      {label:"Premiere Pro", level:"Средний"},
    ].map(s => (
      <div class="glass" style="padding:16px 20px;border-radius:18px;">
        <div style="font-size:14px;font-weight:600;margin-bottom:4px;">{s.label}</div>
        <div style="font-size:11px;color:var(--text-hint);">{s.level}</div>
      </div>
    ))}
  </div>

  <div class="anim-up-5" style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-bottom:40px;">
    <a href="https://vk.com/tim_isa" target="_blank" class="social-link" title="ВКонтакте">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M15.684 0H8.316C1.592 0 0 1.592 0 8.316v7.368C0 22.408 1.592 24 8.316 24h7.368C22.408 24 24 22.408 24 15.684V8.316C24 1.592 22.408 0 15.684 0zm3.692 17.123h-1.744c-.66 0-.864-.525-2.05-1.727-1.033-1.01-1.49-.12-1.49 1.092 0 .315-.12.635-.498.635h-1.065c-3.1 0-5.03-2.157-5.03-4.932 0-3.072 2.07-5.48 5.247-5.48h1.12c.368 0 .523.18.523.567 0 .968-.008.992.008 1.04.112.386.657.534.86-.212.48-1.782 1.58-2.64 2.615-2.64.38 0 .51.24.51.588 0 .33-.15.646-.35 1.018-.5.93-.7 1.868.39 3.093 1.02 1.152 1.46.78 2.003-.17l.645-1.1c.237-.405.5-.405.787-.16l1.31 1.132c.318.28.318.578-.02.87l-.6.693c-.33.39-.2.712.12 1.12.61.79 1.59 2.2.59 3.573z"/></svg>
    </a>
    <a href="https://www.youtube.com/@timteam_" target="_blank" class="social-link" title="YouTube">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
    </a>
    <a href="https://t.me/T1m_11" target="_blank" class="social-link" title="Telegram">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
    </a>
    <a href="mailto:timteamfreelance@gmail.com" class="social-link" title="Email">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </a>
  </div>

  <div class="glass anim-up-5" style="padding:20px 24px;border-radius:20px;font-size:13px;color:var(--text-hint);">
    Discord: <strong style="color:var(--text-muted);">timteam0_0</strong> &nbsp;·&nbsp;
    <a href="https://t.me/Timteam_Universe" target="_blank" style="color:var(--accent);text-decoration:none;">Telegram канал</a> &nbsp;·&nbsp;
    <a href="https://t.me/timteam_blend" target="_blank" style="color:var(--accent);text-decoration:none;">timteam blend</a>
  </div>
</div>
</Layout>