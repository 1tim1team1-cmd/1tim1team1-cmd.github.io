---
import Layout from '../layouts/Layout.astro';
import MiniPlayer from '../components/MiniPlayer.astro';
---
<Layout title="timteam · portfolio" description="3D artist, musician and developer">

  <section style="min-height:90vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px 24px 60px;max-width:900px;margin:0 auto;">

    <div class="anim-up">
      <span class="tag" data-ru="3D · Музыка · VFX · Геймдев" data-en="3D · Music · VFX · Game Dev">3D · Музыка · VFX · Геймдев</span>
    </div>

    <h1 class="anim-up-2" style="font-size:clamp(42px,7vw,80px);font-weight:700;line-height:1.08;letter-spacing:-.03em;margin:16px 0 24px;color:#1e0a4c;">
      <span data-ru="Творческое" data-en="Creative">Творческое</span><br>
      <span style="background:linear-gradient(135deg,#7c3aed,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;" data-ru="портфолио" data-en="portfolio">портфолио</span>
    </h1>

    <p class="anim-up-3" style="font-size:18px;color:var(--text-muted);line-height:1.7;max-width:520px;margin:0 auto 32px;"
       data-ru="3D-художник, музыкант и разработчик. Blender, FL Studio, Unity — создаю миры с нуля."
       data-en="3D artist, musician and developer. Blender, FL Studio, Unity — building worlds from scratch.">
      3D-художник, музыкант и разработчик. Blender, FL Studio, Unity — создаю миры с нуля.
    </p>

    <div class="anim-up-3" style="margin-bottom:40px;display:flex;flex-wrap:wrap;gap:6px;justify-content:center;">
      <span class="skill-chip">Blender</span>
      <span class="skill-chip">After Effects</span>
      <span class="skill-chip">FL Studio</span>
      <span class="skill-chip">Unity</span>
      <span class="skill-chip">Premiere Pro</span>
      <span class="skill-chip">Python</span>
    </div>

    <div class="anim-up-4" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-bottom:60px;">
      <a href="/3d" class="btn btn-primary" data-ru="Смотреть работы" data-en="View portfolio">Смотреть работы</a>
      <a href="/services" class="btn btn-glass" data-ru="Заказать проект" data-en="Order a project">Заказать проект</a>
    </div>

    <div class="anim-up-4" style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:80px;">
      <a href="https://vk.com/tim_isa" target="_blank" rel="noopener" class="social-link" title="ВКонтакте">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M15.684 0H8.316C1.592 0 0 1.592 0 8.316v7.368C0 22.408 1.592 24 8.316 24h7.368C22.408 24 24 22.408 24 15.684V8.316C24 1.592 22.408 0 15.684 0zm3.692 17.123h-1.744c-.66 0-.864-.525-2.05-1.727-1.033-1.01-1.49-.12-1.49 1.092 0 .315-.12.635-.498.635h-1.065c-3.1 0-5.03-2.157-5.03-4.932 0-3.072 2.07-5.48 5.247-5.48h1.12c.368 0 .523.18.523.567 0 .968-.008.992.008 1.04.112.386.657.534.86-.212.48-1.782 1.58-2.64 2.615-2.64.38 0 .51.24.51.588 0 .33-.15.646-.35 1.018-.5.93-.7 1.868.39 3.093 1.02 1.152 1.46.78 2.003-.17l.645-1.1c.237-.405.5-.405.787-.16l1.31 1.132c.318.28.318.578-.02.87l-.6.693c-.33.39-.2.712.12 1.12.61.79 1.59 2.2.59 3.573z"/></svg>
      </a>
      <a href="https://www.youtube.com/@timteam_" target="_blank" rel="noopener" class="social-link" title="YouTube">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
      <a href="https://t.me/T1m_11" target="_blank" rel="noopener" class="social-link" title="Telegram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </a>
      <a href="mailto:timteamfreelance@gmail.com" class="social-link" title="Email">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </a>
      <a href="https://t.me/Timteam_Universe" target="_blank" rel="noopener" class="social-link" title="Telegram channel">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" opacity=".75"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </a>
    </div>

  </section>

  <!-- ─── SECTIONS GRID ───────────────────────────────────── -->
  <section style="padding:0 24px 100px;max-width:900px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;margin-bottom:40px;">

      <!-- Mini Player spans full width -->
      <div style="grid-column:1/-1;margin-bottom:4px;">
        <MiniPlayer />
      </div>

      <a href="/3d" class="section-card glass" style="color:inherit;">
        <div style="font-size:32px;margin-bottom:12px;">🎨</div>
        <div style="font-size:16px;font-weight:600;margin-bottom:6px;" data-ru="3D / Арт" data-en="3D / Art">3D / Арт</div>
        <div style="font-size:13px;color:var(--text-muted);line-height:1.6;" data-ru="Реалистичные рендеры, анимация, персонажи. Blender — мой основной инструмент." data-en="Realistic renders, animation, characters. Blender is my main tool.">Реалистичные рендеры, анимация, персонажи. Blender — мой основной инструмент.</div>
      </a>

      <a href="/music" class="section-card glass" style="color:inherit;">
        <div style="font-size:32px;margin-bottom:12px;">🎵</div>
        <div style="font-size:16px;font-weight:600;margin-bottom:6px;" data-ru="Музыка" data-en="Music">Музыка</div>
        <div style="font-size:13px;color:var(--text-muted);line-height:1.6;" data-ru="Оркестр, хор, рок, поп — пишу всё сам. 13 альбомов · 115 треков · ~6 часов." data-en="Orchestra, choir, rock, pop — all original. 13 albums · 115 tracks · ~6 hours.">Оркестр, хор, рок, поп — пишу всё сам. 13 альбомов · 115 треков · ~6 часов.</div>
      </a>

      <a href="/video" class="section-card glass" style="color:inherit;">
        <div style="font-size:32px;margin-bottom:12px;">🎬</div>
        <div style="font-size:16px;font-weight:600;margin-bottom:6px;" data-ru="Видео / VFX" data-en="Video / VFX">Видео / VFX</div>
        <div style="font-size:13px;color:var(--text-muted);line-height:1.6;" data-ru="After Effects, Premiere Pro, VFX-эффекты и цветокоррекция с LUT." data-en="After Effects, Premiere Pro, VFX effects and color grading with LUTs.">After Effects, Premiere Pro, VFX-эффекты и цветокоррекция с LUT.</div>
      </a>

      <a href="/games" class="section-card glass" style="color:inherit;">
        <div style="font-size:32px;margin-bottom:12px;">🎮</div>
        <div style="font-size:16px;font-weight:600;margin-bottom:6px;" data-ru="Игры" data-en="Games">Игры</div>
        <div style="font-size:13px;color:var(--text-muted);line-height:1.6;" data-ru="Разрабатываю аниме-игру про Кэсси. Unity, авторский 3D-персонаж." data-en="Developing an anime game about Cassy. Unity, original 3D character.">Разрабатываю аниме-игру про Кэсси. Unity, авторский 3D-персонаж.</div>
      </a>

      <a href="/services" class="section-card glass" style="color:inherit;grid-column:1/-1;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
        <div>
          <div style="font-size:16px;font-weight:600;margin-bottom:6px;" data-ru="Заказать проект" data-en="Order a project">Заказать проект</div>
          <div style="font-size:13px;color:var(--text-muted);" data-ru="3D, монтаж, музыка, разработка сайта — от 1 800 ₽" data-en="3D, editing, music, web dev — from $30">3D, монтаж, музыка, разработка сайта — от 1 800 ₽</div>
        </div>
        <span class="btn btn-primary" style="pointer-events:none;" data-ru="Смотреть услуги →" data-en="View services →">Смотреть услуги →</span>
      </a>

    </div>
  </section>

</Layout>
