---
import Layout from '../layouts/Layout.astro';
---
<Layout title="timteam · 3D / Арт" description="3D рендеры, анимация, персонажи — Blender">
<div style="max-width:960px;margin:0 auto;padding:40px 24px 100px;">

  <div class="anim-up"><span class="tag">Blender · реализм · стилизация</span></div>
  <h1 class="anim-up-2" style="font-size:clamp(32px,5vw,56px);font-weight:700;letter-spacing:-.02em;margin:16px 0 12px;">3D / Арт</h1>
  <p class="anim-up-3" style="font-size:16px;color:var(--text-muted);line-height:1.7;max-width:500px;margin-bottom:48px;">
    Реалистичные рендеры, стилизованные персонажи, анимация. FNAF, Кэсси и многое другое.
  </p>

  <!-- Фильтры -->
  <div class="anim-up-3" id="filters" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:32px;">
    <button class="filter-btn active" data-filter="all" onclick="filterRenders('all')">Все</button>
    <button class="filter-btn" data-filter="light" onclick="filterRenders('light')">Светлые работы</button>
    <button class="filter-btn" data-filter="dark" onclick="filterRenders('dark')">Тёмные / FNAF</button>
  </div>

  <div class="anim-up-4" id="gallery" style="columns:2 280px;gap:16px;"></div>

  <!-- Пусто -->
  <div id="gallery-empty" style="display:none;text-align:center;padding:80px 24px;">
    <div style="font-size:48px;margin-bottom:16px;">🎨</div>
    <div style="font-size:16px;font-weight:600;margin-bottom:8px;">Рендеры появятся здесь</div>
    <div style="font-size:13px;color:var(--text-muted);">Добавь фото в <code>public/renders/</code> и запусти <code>python admin.py</code></div>
  </div>

  <!-- Лайтбокс -->
  <div id="lightbox" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(14,0,40,0.85);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);align-items:center;justify-content:center;padding:24px;" onclick="closeLightbox(event)">
    <div style="max-width:800px;width:100%;position:relative;" onclick="event.stopPropagation()">
      <img id="lb-img" src="" alt="" style="width:100%;border-radius:20px;display:block;max-height:80vh;object-fit:contain;" />
      <div class="glass" style="margin-top:16px;padding:16px 20px;border-radius:16px;">
        <div id="lb-title" style="font-size:16px;font-weight:600;margin-bottom:4px;"></div>
        <div id="lb-desc" style="font-size:13px;color:var(--text-muted);line-height:1.6;"></div>
        <div id="lb-tags" style="margin-top:8px;display:flex;flex-wrap:wrap;gap:6px;"></div>
      </div>
      <button onclick="closeLightbox()" style="position:absolute;top:-14px;right:-14px;width:36px;height:36px;border-radius:50%;background:#fff;border:none;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(0,0,0,0.2);transition:transform .25s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">×</button>
    </div>
  </div>

</div>

<style>
.filter-btn {
  padding: 7px 18px;
  border-radius: 100px;
  border: 1px solid var(--glass-border-vis);
  background: rgba(255,255,255,0.5);
  color: var(--text-muted);
  font-size: 13px;
  cursor: pointer;
  transition: background .25s, color .25s, transform .25s cubic-bezier(.22,.68,0,1.3), box-shadow .25s;
  backdrop-filter: blur(8px);
}
.filter-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(124,58,237,0.15); }
.filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }

.render-card {
  break-inside: avoid;
  margin-bottom: 16px;
  border-radius: 20px;
  overflow: hidden;
  cursor: pointer;
  transition: transform .3s cubic-bezier(.22,.68,0,1.3), box-shadow .3s ease;
  position: relative;
}
.render-card:hover { transform: translateY(-6px) scale(1.02); box-shadow: 0 20px 48px rgba(124,58,237,0.22); }
.render-card img { width: 100%; display: block; border-radius: 20px; }
.render-overlay {
  position: absolute; inset: 0; border-radius: 20px;
  background: linear-gradient(to top, rgba(14,0,40,0.75) 0%, transparent 60%);
  opacity: 0; transition: opacity .3s ease;
  display: flex; align-items: flex-end; padding: 16px;
}
.render-card:hover .render-overlay { opacity: 1; }
.render-card.dark-style img { filter: brightness(0.92) saturate(0.9); }
</style>

<script is:inline>
let allRenders = [];
let currentFilter = 'all';

async function loadRenders() {
  try {
    const r = await fetch('/data/renders.json');
    allRenders = await r.json();
  } catch {
    allRenders = [];
  }
  renderGallery();
}

function renderGallery() {
  const gallery = document.getElementById('gallery');
  const empty = document.getElementById('gallery-empty');
  const filtered = currentFilter === 'all' ? allRenders : allRenders.filter(r => r.style === currentFilter);

  if (!filtered.length) {
    gallery.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';
  gallery.innerHTML = '';

  filtered.forEach((r, i) => {
    const card = document.createElement('div');
    card.className = `render-card${r.style==='dark'?' dark-style':''}`;
    card.style.animationDelay = `${i * 0.05}s`;
    card.onclick = () => openLightbox(r);

    const isDark = r.style === 'dark';
    card.innerHTML = `
      <img src="${r.file}" alt="${r.title}" loading="lazy" onerror="this.parentElement.style.display='none'" />
      <div class="render-overlay" style="${isDark?'background:linear-gradient(to top,rgba(14,0,40,0.85) 0%,transparent 60%);':''}">
        <span style="color:#fff;font-size:13px;font-weight:600;text-shadow:0 1px 8px rgba(0,0,0,0.5);">${r.title}</span>
      </div>
    `;
    gallery.appendChild(card);
  });
}

window.filterRenders = function(filter) {
  currentFilter = filter;
  document.querySelectorAll('.filter-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.filter === filter);
  });
  renderGallery();
};

window.openLightbox = function(r) {
  const lb = document.getElementById('lightbox');
  document.getElementById('lb-img').src = r.file;
  document.getElementById('lb-title').textContent = r.title;
  document.getElementById('lb-desc').textContent = r.description || '';
  const tagsEl = document.getElementById('lb-tags');
  tagsEl.innerHTML = (r.tags||[]).map(t => `<span class="tag">${t}</span>`).join('');
  lb.style.display = 'flex';
  document.body.style.overflow = 'hidden';
};

window.closeLightbox = function(e) {
  if (!e || e.target === document.getElementById('lightbox') || !e.target.closest) {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = '';
  }
};

document.addEventListener('keydown', e => { if(e.key==='Escape') window.closeLightbox(); });

loadRenders();
</script>
</Layout>